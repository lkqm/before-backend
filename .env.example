APP_ENV=dev
PORT=3000
ENABLE_SWAGGER=true
DATABASE_URL="mysql://before:before_dev_password@localhost:3306/before"
AUTH_TOKEN_SECRET=""
AUTH_TOKEN_TTL_MS=2592000000
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_TLS_REJECT_UNAUTHORIZED=true
WECHAT_REQUEST_TIMEOUT_MS=8000
SIGNUP_AI_CREDITS=10
AI_PROVIDER="openai"
AI_BASE_URL=""
AI_API_KEY=""
AI_MODEL="gpt-4.1-mini"
AI_TIMEOUT_MS=
AI_MAX_RETRIES=
TEXT_AI_PROVIDER=""
TEXT_AI_BASE_URL=""
TEXT_AI_API_KEY=""
TEXT_AI_MODEL=""
TEXT_AI_TIMEOUT_MS=15000
TEXT_AI_MAX_RETRIES=0
AI_REWRITE_MAX_TOKENS=120
AI_REWRITE_TEMPERATURE=0.7
AI_REWRITE_THINKING_DISABLED=true
AI_TEXT_CAPTION_MAX_TOKENS=240
AI_TEXT_CAPTION_TEMPERATURE=0.7
AI_TEXT_CAPTION_THINKING_DISABLED=true
IMAGE_AI_PROVIDER=""
IMAGE_AI_BASE_URL=""
IMAGE_AI_API_KEY=""
IMAGE_AI_MODEL=""
IMAGE_AI_TIMEOUT_MS=30000
IMAGE_AI_MAX_RETRIES=0
AI_IMAGE_CAPTION_MAX_IMAGES=4
AI_IMAGE_CAPTION_MAX_TOKENS=220
AI_IMAGE_CAPTION_TEMPERATURE=0.7
AI_IMAGE_CAPTION_THINKING_DISABLED=true

# Provider examples:
# OpenAI:   AI_PROVIDER=openai  AI_BASE_URL=                         AI_MODEL=gpt-4.1-mini
# DeepSeek: AI_PROVIDER=deepseek AI_BASE_URL=https://api.deepseek.com AI_MODEL=deepseek-chat
# Qwen:     AI_PROVIDER=qwen     AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1 AI_MODEL=qwen-plus
# Kimi:     AI_PROVIDER=kimi     AI_BASE_URL=https://api.moonshot.cn/v1 AI_MODEL=kimi-k2.5
# Doubao:   AI_PROVIDER=doubao   AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3 AI_MODEL=<your-volcengine-endpoint-id-or-model>
