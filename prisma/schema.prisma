generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AiFeature {
  ai
  caption
  image_rank
  rewrite
}

enum AiUsageStatus {
  success
  failed
  blocked
  timeout
}

enum AiFeedbackResult {
  accepted
  dismissed
  reverted
}

model User {
  id        String   @id @default(cuid())
  openId    String   @unique
  unionId    String?  @unique
  nickname  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiUsages    AiUsage[]
  aiFeedbacks AiFeedback[]
  aiCreditAccount AiCreditAccount?
  aiCreditLedgers AiCreditLedger[]
  billingInterests BillingInterest[]
}

model AiUsage {
  id             String        @id @default(cuid())
  requestId      String        @unique
  userId         String
  provider       String
  feature        AiFeature
  model          String
  inputTokens    Int?
  outputTokens   Int?
  costEstimate   Decimal?      @db.Decimal(12, 6)
  status         AiUsageStatus
  latencyMs      Int?
  errorMessage   String?
  createdAt      DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbacks AiFeedback[]

  @@index([userId, feature, createdAt])
}

model AiFeedback {
  id        String           @id @default(cuid())
  userId    String
  aiUsageId String
  result    AiFeedbackResult
  metadata  Json?
  createdAt DateTime         @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiUsage AiUsage @relation(fields: [aiUsageId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([result, createdAt])
  @@unique([aiUsageId])
}

model AiCreditAccount {
  userId    String   @id
  balance   Int      @default(0)
  totalAdded Int     @default(0)
  totalUsed  Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiCreditLedger {
  id        String     @id @default(cuid())
  userId    String
  delta     Int
  balance   Int
  reason    String
  dedupeKey String?    @unique
  feature   AiFeature?
  aiUsageId String?
  metadata  Json?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model BillingInterest {
  id               String   @id @default(cuid())
  userId           String
  feature          AiFeature
  remainingCredits Int?
  metadata         Json?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
}
