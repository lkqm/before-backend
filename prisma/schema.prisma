generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  openId    String   @unique
  unionId   String?  @unique
  nickname  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiUsages         AiUsage[]
  aiFeedbacks      AiFeedback[]
  aiCreditAccount  AiCreditAccount?
  aiCreditLedgers  AiCreditLedger[]
  billingInterests BillingInterest[]
}

model AiProvider {
  id             String    @id @default(cuid())
  key            String    @unique @db.VarChar(64)
  type           String    @db.VarChar(64)
  baseUrl        String?
  apiKey         String?   @db.Text
  timeoutMs      Int
  imageTimeoutMs Int
  maxRetries     Int
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  models AiModel[]
}

model AiModel {
  id               String    @id @default(cuid())
  providerId       String
  key              String    @db.VarChar(64)
  modelId          String
  capabilities     Json
  supportsJsonMode Boolean   @default(false)
  supportsThinking Boolean   @default(false)
  pricing          Json?
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  provider   AiProvider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  taskModels AiTaskModel[]

  @@unique([providerId, key])
  @@unique([providerId, modelId])
}

model AiTask {
  id           String    @id @default(cuid())
  key          String    @unique @db.VarChar(64)
  mode         String    @db.VarChar(32)
  strategy     String?   @db.VarChar(32)
  maxImages    Int?
  maxTokens    Int?
  temperature  Float?
  systemPrompt String?   @db.Text
  thinking     Boolean   @default(false)
  jsonMode     Boolean   @default(false)
  enabled      Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  taskModels AiTaskModel[]
}

model AiTaskModel {
  id        String   @id @default(cuid())
  taskId    String
  modelId   String
  weight    Int      @default(100)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task  AiTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  model AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([taskId, modelId])
}

model AiUsage {
  id           String        @id @default(cuid())
  requestId    String        @unique
  userId       String
  provider     String
  feature      String        @db.VarChar(32)
  model        String
  inputTokens  Int?
  outputTokens Int?
  costEstimate Decimal?      @db.Decimal(12, 6)
  status       String        @db.VarChar(32)
  latencyMs    Int?
  errorMessage String?       @db.Text
  metadata     Json?
  createdAt    DateTime      @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbacks AiFeedback[]

  @@index([userId, feature, createdAt])
}

model AiFeedback {
  id        String           @id @default(cuid())
  userId    String
  aiUsageId String
  result    String   @db.VarChar(32)
  metadata  Json?
  createdAt DateTime         @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiUsage AiUsage @relation(fields: [aiUsageId], references: [id], onDelete: Cascade)

  @@unique([aiUsageId])
  @@index([userId, createdAt])
  @@index([result, createdAt])
}

model AiCreditAccount {
  userId     String   @id
  balance    Int      @default(0)
  totalAdded Int      @default(0)
  totalUsed  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiCreditLedger {
  id        String     @id @default(cuid())
  userId    String
  delta     Int
  balance   Int
  reason    String
  dedupeKey String?    @unique
  feature   String?    @db.VarChar(32)
  aiUsageId String?
  metadata  Json?
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model BillingInterest {
  id               String    @id @default(cuid())
  userId           String
  feature          String    @db.VarChar(32)
  remainingCredits Int?
  metadata         Json?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
}
